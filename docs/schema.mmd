
erDiagram

    SURVEY ||--o{ QUESTION : contiene
    QUESTION ||--o{ OPTION : tiene
    SURVEY ||--o{ RESPONSE : recibe
    RESPONSE ||--o{ ANSWER : incluye
    QUESTION ||--o{ ANSWER : es_contestada

    SURVEY {
        string survey_id PK
        string titulo
        string descripcion
        string publico_objetivo
        boolean activa
    }

    QUESTION {
        string question_id PK
        string enunciado
        string tipo
        boolean obligatoria
        string survey_id FK
    }

    OPTION {
        string option_id PK
        string texto
        string question_id FK
    }

    RESPONSE {
        string response_id PK
        string participante
        date fecha_respuesta
        string survey_id FK
    }

    ANSWER {
        string answer_id PK
        string opcion_elegida
        string question_id FK
        string response_id FK
    }
